local function GetIcon(Icon)
    if typeof(Icon) == "string" then
        local CleanName = Icon:gsub("[%[%]]", ""):lower()
        if Icons[CleanName] then return Icons[CleanName] end
        if CleanName:match("^lucide%-") then
            if Compkiller.Lucide[CleanName] then return Compkiller.Lucide[CleanName] end
        else
            if Compkiller.Lucide["lucide-" .. CleanName] then return Compkiller.Lucide["lucide-" .. CleanName] end
        end
        if Icon:find("rbxassetid://") then return Icon end
    end
    return Icons.Placeholder
end

