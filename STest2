                    local ScreenSize = ScreenGui.AbsoluteSize
                    local X = BtnPos.X - 230
                    local Y = BtnPos.Y + 25

                    if X < 0 then X = BtnPos.X + 35 end
                    if Y + 225 > ScreenSize.Y then Y = ScreenSize.Y - 230 end

                    PickerFrame.Position = UDim2.new(0, X, 0, Y)
