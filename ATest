        Instance.new("UICorner").CornerRadius = UDim.new(0, 4)
        Instance.new("UICorner").Parent = wheel
        slide.Parent = wheel
        slide.BackgroundColor3 = windowConfig.Hightlight
        slide.Size = UDim2.new((config.Default - config.Min) / (config.Max - config.Min), 0, 1, 0)
        slide.BackgroundTransparency = 1
        Instance.new("UICorner").CornerRadius = UDim.new(0, 4)
        Instance.new("UICorner").Parent = slide
        bth.Parent = slide
        bth.AnchorPoint = Vector2.new(1, 0.5)
        bth.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        bth.Position = UDim2.new(1, 5, 0.5, 0)
        bth.Size = UDim2.new(0, 10, 0, 10)
        bth.BackgroundTransparency = 1
        Instance.new("UICorner").CornerRadius = UDim.new(1, 0)
        Instance.new("UICorner").Parent = bth
        
        local Value = config.Default
        local IsHold = false
        local function update(Input)
            local SizeScale = math.clamp((Input.Position.X - wheel.AbsolutePosition.X) / wheel.AbsoluteSize.X, 0, 1)
            local Main = ((config.Max - config.Min) * SizeScale) + config.Min
            local Round = config.Round and (math.floor(Main * (10^config.Round) + 0.5) / (10^config.Round)) or Main
            Value = math.clamp(Round, config.Min, config.Max)
            local normalized = (Value - config.Min) / (config.Max - config.Min)
            TweenService:Create(slide, TweenInfo.new(0.2), {Size = UDim2.new(normalized, 0, 1, 0)}):Play()
            VText.Text = tostring(Value)
            config.Callback(Value)
        end
        wheel.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                IsHold = true
                update(Input)
            end
        end)
        wheel.InputEnded:Connect(function() IsHold = false end)
        UserInputService.InputChanged:Connect(function(Input)
            if IsHold and Input.UserInputType == Enum.UserInputType.MouseMovement then
                update(Input)
            end
        end)
        
        local tableback = {
            Edit = function(self, Value) PText.Text = Value end,
            SetValue = function(self, Value)
                Value = math.clamp(Value, config.Min, config.Max)
                local normalized = (Value - config.Min) / (config.Max - config.Min)
                slide.Size = UDim2.new(normalized, 0, 1, 0)
                VText.Text = tostring(Value)
                config.Callback(Value)
            end,
            GetValue = function(self) return Value end,
            Visible = function(self, Value) SliderFrame.Visible = Value end,
            Destroy = function(self) SliderFrame:Destroy(); end,
        };
        return tableback
    end;

