        VText.TextColor3 = Color3.fromRGB(255, 255, 255)
        VText.TextSize = 13
        VText.TextTransparency = 1
        
        local CurrentKey = config.Default
        local IsBinding = false
        local function UpdateScale()
            local size = TextService:GetTextSize(VText.Text, 13, Enum.Font.GothamMedium, Vector2.new(math.huge, math.huge))
            TweenService:Create(block, TweenInfo.new(0.1), {Size = UDim2.new(0, size.X + 22, 0, 22)}):Play()
        end
        UpdateScale()
        
        Airflow:NewInput(block, function()
            if IsBinding then return end
            IsBinding = true
            VText.Text = "..."
            UpdateScale()
            local Selected = nil
            while not Selected do
                local Key = UserInputService.InputBegan:Wait()
                if Key.KeyCode ~= Enum.KeyCode.Unknown then
                    Selected = Key.KeyCode
                elseif Key.UserInputType == Enum.UserInputType.MouseButton1 then
                    Selected = "MouseLeft"
                elseif Key.UserInputType == Enum.UserInputType.MouseButton2 then
                    Selected = "MouseRight"
                end
            end
            CurrentKey = Selected
            VText.Text = GetItem(Selected)
            UpdateScale()
            IsBinding = false
            config.Callback(CurrentKey)
        end)
        
        local tableback = {
            Edit = function(self, Value) PText.Text = Value end,
            SetValue = function(self, Value) CurrentKey = Value; VText.Text = GetItem(Value); UpdateScale(); config.Callback(Value) end,
