        IconImg.Parent = TabBtn
        IconImg.AnchorPoint = Vector2.new(0.5, 0.5)
        IconImg.Position = UDim2.new(0.5, 0, 0.5, 0)
        IconImg.Size = UDim2.new(0, 22, 0, 22)
        IconImg.BackgroundTransparency = 1
        IconImg.Image = Airflow:GetIcon(cfg.Icon)
        IconImg.ImageColor3 = Color3.fromRGB(255, 255, 255)
        
        local Highlight = Instance.new("Frame")
        Highlight.Parent = TabBtn
        Highlight.AnchorPoint = Vector2.new(1, 0.5)
        Highlight.BackgroundColor3 = Response.Hightlight
        Highlight.Position = UDim2.new(1, 0, 0.5, 0)
        Highlight.Size = UDim2.new(0, 2, 1, 0)
        Highlight.BackgroundTransparency = 1
        
        -- Tab Panel (berisi Left dan Right sections dengan scroll independen)
        local TabPanel = Instance.new("Frame")
        TabPanel.Parent = content
        TabPanel.BackgroundTransparency = 1
        TabPanel.Size = UDim2.new(1, 0, 0, 0)
        TabPanel.AutomaticSize = Enum.AutomaticSize.Y
        TabPanel.Visible = false
        
        -- Left Column (scroll independen)
        local LeftColumn = Instance.new("ScrollingFrame")
        LeftColumn.Parent = TabPanel
        LeftColumn.AnchorPoint = Vector2.new(0, 0)
        LeftColumn.Position = UDim2.new(0, 0, 0, 0)
        LeftColumn.Size = UDim2.new(0.5, -10, 0, 0)
        LeftColumn.BackgroundTransparency = 1
        LeftColumn.BorderSizePixel = 0
        LeftColumn.ScrollBarThickness = 4
        LeftColumn.ScrollBarImageColor3 = Color3.fromRGB(50, 50, 55)
        LeftColumn.ClipsDescendants = true
        LeftColumn.AutomaticSize = Enum.AutomaticSize.Y
        
        local LeftLayout = Instance.new("UIListLayout")
        LeftLayout.Parent = LeftColumn
        LeftLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        LeftLayout.SortOrder = Enum.SortOrder.LayoutOrder
        LeftLayout.Padding = UDim.new(0, 5)
        
        LeftLayout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(function()
            LeftColumn.CanvasSize = UDim2.fromOffset(0, LeftLayout.AbsoluteContentSize.Y + 10)
        end)
        
        -- Right Column (scroll independen)
        local RightColumn = Instance.new("ScrollingFrame")
        RightColumn.Parent = TabPanel
        RightColumn.AnchorPoint = Vector2.new(1, 0)
        RightColumn.Position = UDim2.new(1, 0, 0, 0)
        RightColumn.Size = UDim2.new(0.5, -10, 0, 0)
        RightColumn.BackgroundTransparency = 1
        RightColumn.BorderSizePixel = 0
        RightColumn.ScrollBarThickness = 4
        RightColumn.ScrollBarImageColor3 = Color3.fromRGB(50, 50, 55)
        RightColumn.ClipsDescendants = true
        RightColumn.AutomaticSize = Enum.AutomaticSize.Y
        
        local RightLayout = Instance.new("UIListLayout")
        RightLayout.Parent = RightColumn
        RightLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        RightLayout.SortOrder = Enum.SortOrder.LayoutOrder
        RightLayout.Padding = UDim.new(0, 5)
        
        RightLayout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(function()
            RightColumn.CanvasSize = UDim2.fromOffset(0, RightLayout.AbsoluteContentSize.Y + 10)
        end)
        
        -- Set column heights based on content
        local function UpdatePanelHeight()
            local leftHeight = LeftLayout.AbsoluteContentSize.Y
            local rightHeight = RightLayout.AbsoluteContentSize.Y
            local maxHeight = math.max(leftHeight, rightHeight)
            LeftColumn.Size = UDim2.new(0.5, -10, 0, maxHeight + 10)
            RightColumn.Size = UDim2.new(0.5, -10, 0, maxHeight + 10)
            TabPanel.Size = UDim2.new(1, 0, 0, maxHeight + 20)
        end
        
        LeftLayout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(UpdatePanelHeight)
        RightLayout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(UpdatePanelHeight)
        
        local Bindable = Instance.new('BindableEvent', TabBtn)
        local LeftElements = Airflow:Elements(LeftColumn, Bindable, config)
        local RightElements = Airflow:Elements(RightColumn, Bindable, config)
        
        local TabTable = {
            Left = LeftElements,
            Right = RightElements,
            Name = cfg.Name,
            Panel = TabPanel,
            TabButton = TabBtn,
            Sections = {},
            ID = #Response.TabElements,
        }
        
        -- Activate/Deactivate Tab
        local function ActivateTab(active)
            if active then
                Response.CurrentTabName = TabTable.Name
                if not Response.SearchMode then
                    InternalTabLabel.Text = TabTable.Name
                end
                for _, v in pairs(Response.TabElements) do
                    if v ~= ActivateTab then v(false) end
                end
                TabPanel.Visible = true
                if Response.TabScrolls[TabTable.Name] then
                    Body.CanvasPosition = Response.TabScrolls[TabTable.Name]
                end
                Airflow:CreateAnimation(Highlight, 0.3, nil, {BackgroundTransparency = 0})
                Airflow:CreateAnimation(TabBtn, 0.3, nil, {BackgroundTransparency = 0.8})
                Airflow:CreateAnimation(IconImg, 0.3, nil, {ImageTransparency = 0})
                Bindable:Fire(true)
            else
                Response.TabScrolls[TabTable.Name] = Body.CanvasPosition
                TabPanel.Visible = false
                Airflow:CreateAnimation(TabBtn, 0.3, nil, {BackgroundTransparency = 1})
                Airflow:CreateAnimation(Highlight, 0.3, nil, {BackgroundTransparency = 1})
                Airflow:CreateAnimation(IconImg, 0.3, nil, {ImageTransparency = 0.3})
                Bindable:Fire(false)
            end
        end
        
        if #Response.TabElements == 0 then
            ActivateTab(true)
        end
        
        table.insert(Response.TabElements, ActivateTab)
        
        TabBtn.MouseButton1Click:Connect(function()
            for _, v in pairs(Response.TabElements) do
                v(v == ActivateTab)
            end
        end)
        
        -- Add Section to Tab
        function TabTable:AddSection(cfg)
            cfg = cfg or {Name = "Section", Position = "left"}
            
            local SectionBase = Instance.new("Frame")
            local Section = Instance.new("Frame")
            local LabelFrame = Instance.new("TextLabel")
            local SectionLayout = Instance.new("UIListLayout")
            
            SectionBase.Parent = (cfg.Position == "left" and LeftColumn) or RightColumn
            SectionBase.BackgroundTransparency = 1
            SectionBase.Size = UDim2.new(1, -6, 0, 150)
            
            Section.Parent = SectionBase
            Section.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
            Section.BackgroundTransparency = 0.5
            Section.Position = UDim2.new(0, 0, 0, 15)
            Section.Size = UDim2.new(1, 0, 1, -15)
            Section.ClipsDescendants = true
            Instance.new("UICorner").CornerRadius = UDim.new(0, 4)
            Instance.new("UICorner").Parent = Section
            
            local Stroke = Instance.new("UIStroke")
            Stroke.Parent = Section
            Stroke.Color = Color3.fromRGB(60, 60, 60)
            Stroke.Thickness = 1
            
            LabelFrame.Parent = SectionBase
            LabelFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
            LabelFrame.BackgroundTransparency = 1
            LabelFrame.Position = UDim2.new(0, 12, 0, 0)
            LabelFrame.Size = UDim2.new(0, 50, 0, 20)
            LabelFrame.Font = Enum.Font.GothamBold
            LabelFrame.Text = cfg.Name
            LabelFrame.TextColor3 = Color3.fromRGB(220, 220, 220)
            LabelFrame.TextSize = 12
            LabelFrame.TextXAlignment = Enum.TextXAlignment.Left
            
            SectionLayout.Parent = Section
            SectionLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
            SectionLayout.SortOrder = Enum.SortOrder.LayoutOrder
            SectionLayout.Padding = UDim.new(0, 3)
            
            local Padding = Instance.new("UIPadding")
            Padding.Parent = Section
            Padding.PaddingTop = UDim.new(0, 5)
            Padding.PaddingBottom = UDim.new(0, 5)
            
            local SectionElements = Airflow:Elements(Section, Bindable, config)
            
            SectionLayout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(function()
                local newSize = SectionLayout.AbsoluteContentSize.Y + 10
                SectionBase.Size = UDim2.new(1, -6, 0, newSize + 15)
                Section.Size = UDim2.new(1, 0, 0, newSize)
                UpdatePanelHeight()
            end)
            
            table.insert(TabTable.Sections, SectionElements)
            
            -- Register elements for search
            local function RegisterElementsRecursive(elementsTable, sectionName)
                for id, info in pairs(elementsTable:GetInfo() or {}) do
                    if info.Name then
                        table.insert(Response.AllElements, {
                            Title = info.Name,
                            Frame = info.API._frame or SectionBase,
                            Section = sectionName
                        })
                    end
                end
            end
            
            RegisterElementsRecursive(SectionElements, cfg.Name)
            
            return SectionElements
        end
        
        function TabTable:GetConfigs()
            local sections = {}
            for i, v in pairs(TabTable.Sections) do
                sections["Section_"..i] = v:GetConfigs()
            end
            return {
                Left = LeftElements:GetConfigs(),
                Right = RightElements:GetConfigs(),
                Sections = sections,
            }
        end
        
        table.insert(Response.TabConfig, TabTable)
        return TabTable
    end
    
    -- Resizable (optional)
    if config.Resizable then
        local Resize = Instance.new("TextButton")
        Resize.Parent = WindowFrame
        Resize.AnchorPoint = Vector2.new(0.5, 0.5)
        Resize.BackgroundTransparency = 1
        Resize.Position = UDim2.new(1, 0, 1, 0)
        Resize.Size = UDim2.new(0.075, 0, 0.075, 0)
        Resize.SizeConstraint = Enum.SizeConstraint.RelativeYY
        Resize.Text = ""
        
        local isResizing = false
        Resize.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                isResizing = true
            end
        end)
        Resize.InputEnded:Connect(function()
            isResizing = false
        end)
        UserInputService.InputChanged:Connect(function(input)
            if isResizing and input.UserInputType == Enum.UserInputType.MouseMovement then
                local x = math.max(483, input.Position.X - WindowFrame.AbsolutePosition.X)
                local y = math.max(297, input.Position.Y - WindowFrame.AbsolutePosition.Y)
                WindowFrame.Size = UDim2.new(0, x, 0, y)
                config.Scale = WindowFrame.Size
            end
        end)
    end
    
    -- Start with window open
    ToggleWindow(true)
    
    return Response
end

return Airflow
