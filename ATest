                    if UserInputService.TouchEnabled then
                        if not Airflow:IsMouseOverFrame(SliderFrame) then
                            IsHold = false
                        else
                            update(Input)
                        end;
                    else
                        update(Input)
                    end;
                end;
            end;
        end);
        ElementId += 1;
        local tableback = {
            Edit = function(self, Value) PText.Text = Value end,
