    local function updateSearch(query)
        local lowerQuery = string.lower(query)
        Response.SearchQuery = lowerQuery
        
        if lowerQuery == "" then
            Response.SearchMode = false
            Body.Visible = true
            SearchContent.Visible = false
            NoResultsLabel.Visible = false
            InternalTabLabel.Text = Response.CurrentTabName or "None"
            return
        end
        
        Response.SearchMode = true
        Body.Visible = false
        SearchContent.Visible = true
        
        for _, child in pairs(SearchContent:GetChildren()) do
            if child:IsA("Frame") and child ~= SearchLayout then
                child:Destroy()
            end
        end
        
        local foundCount = 0
        for _, elem in pairs(Response.AllElements) do
            if string.find(string.lower(elem.Title or ""), lowerQuery) then
                local clone = elem.Frame:Clone()
                clone.Parent = SearchContent
                clone.LayoutOrder = foundCount
                clone.Visible = true
                foundCount = foundCount + 1
            end
        end
        
        NoResultsLabel.Visible = (foundCount == 0)
        InternalTabLabel.Text = "Search: " .. lowerQuery
    end

