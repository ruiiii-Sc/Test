            local FoundMatches = 0
            for _, Comp in WindowObj.AllRows do
                if string.find(string.lower(Comp.Title), Query) then
                    Comp.Row.Parent = SearchContent; FoundMatches = FoundMatches + 1
                end
            end
            NoResultsLabel.Visible = (FoundMatches == 0)
        end
    end)

