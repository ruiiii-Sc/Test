local Compkiller = { Lucide = {} }
local IconRegistry = { Contexts = {}, Cache = {} }

local function RegisterIconContext(ContextName, ContextData)
    IconRegistry.Contexts[ContextName] = ContextData or {}
    for key, _ in pairs(IconRegistry.Cache) do
        if key:find("|" .. ContextName .. "$") then IconRegistry.Cache[key] = nil end
    end
end

local function GetIcon(Icon, Context)
    if Icon == nil or Icon == "" or Icon == "--" then return nil end
    if typeof(Icon) ~= "string" then return nil end
    local CacheKey = Icon .. "|" .. (Context or "default")
    if IconRegistry.Cache[CacheKey] ~= nil then
        local cached = IconRegistry.Cache[CacheKey]
        return cached ~= false and cached or nil
    end
    local ResolvedIcon = nil
    if Context and IconRegistry.Contexts[Context] then
        ResolvedIcon = IconRegistry.Contexts[Context][Icon] or IconRegistry.Contexts[Context][Icon:lower()]
    end
    if not ResolvedIcon then
        local CleanName = Icon:gsub("[%[%]]", ""):lower()
        if Icons[CleanName] then ResolvedIcon = Icons[CleanName]
        elseif CleanName:match("^lucide%-") then ResolvedIcon = Compkiller.Lucide[CleanName]
        elseif Compkiller.Lucide["lucide-" .. CleanName] then ResolvedIcon = Compkiller.Lucide["lucide-" .. CleanName]
        elseif Compkiller.FontAwesome and Compkiller.FontAwesome[CleanName] then ResolvedIcon = Compkiller.FontAwesome[CleanName]
        end
    end
    if not ResolvedIcon and Icon:find("rbxassetid://") then ResolvedIcon = Icon end
    IconRegistry.Cache[CacheKey] = ResolvedIcon or false
    return ResolvedIcon
end

local function SafeGetIcon(IconName, AllowPlaceholder)
    if not IconName or IconName == "" or IconName == "--" then return AllowPlaceholder and Icons.Placeholder or nil end
    local Icon = GetIcon(IconName)
    if not Icon and AllowPlaceholder then return Icons.Placeholder end
    return Icon
end

Compkiller.GetIcon = GetIcon
Compkiller.SafeGetIcon = SafeGetIcon
Compkiller.RegisterIconContext = RegisterIconContext
Compkiller.IconRegistry = IconRegistry

-- Helper to wrap text every N words
local function WrapText(text, wordsPerLine)
    if not text or text == "" then return "" end
    wordsPerLine = wordsPerLine or 5
    local words = {}
    for word in text:gmatch("%S+") do table.insert(words, word) end
    local lines = {}
    for i = 1, #words, wordsPerLine do
        local lineWords = {}
        for j = i, math.min(i + wordsPerLine - 1, #words) do table.insert(lineWords, words[j]) end
        table.insert(lines, table.concat(lineWords, " "))
    end
    return table.concat(lines, "\n")
end

