            BorderSizePixel = 0, ScrollBarThickness = 4, ScrollBarImageColor3 = Theme.Accent, CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y, Parent = TabCanvas
        })
        Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4), Parent = TabContent})

        ThemeUpdate(function()
            if WindowObj.CurrentTab and WindowObj.CurrentTab.TabButton == TabBtn then
                TabBtn.BackgroundColor3 = Theme.Search
                if TabIconImage then TabIconImage.ImageColor3 = Theme.Accent end
                local txtLbl = not TabIconImage and TabBtn:FindFirstChildOfClass("TextLabel")
                if txtLbl then txtLbl.TextColor3 = Theme.Accent end
                TabBtnStroke.Transparency = 0
            else
                TabBtn.BackgroundColor3 = Theme.Sidebar
                if TabIconImage then TabIconImage.ImageColor3 = Theme.TextSecondary end
                local txtLbl = not TabIconImage and TabBtn:FindFirstChildOfClass("TextLabel")
                if txtLbl then txtLbl.TextColor3 = Theme.TextSecondary end
                TabBtnStroke.Transparency = 1
            end
            TabContent.ScrollBarImageColor3 = Theme.Accent
        end)

        local TabObj = {Canvas = TabCanvas, Container = TabContent, TabButton = TabBtn, Title = TabTitle, Icon = TabIcon, IsConfig = IsConfig, LayoutOrder = 0}
        table.insert(WindowObj.Tabs, TabObj)

        local function ActivateTab()
            if WindowObj.CurrentTab == TabObj then return end
            for _, Tab in WindowObj.Tabs do
                if Tab == TabObj then continue end
                if Tab == WindowObj.CurrentTab then
                    local Outgoing = Tab
                    local tw = TweenService:Create(Outgoing.Canvas, TweenSmooth, {GroupTransparency = 1})
                    tw:Play()
                    task.delay(0.25, function() if WindowObj.CurrentTab ~= Outgoing then Outgoing.Canvas.Visible = false end end)
                else
                    Tab.Canvas.Visible = false; Tab.Canvas.GroupTransparency = 1
                end
                TweenService:Create(Tab.TabButton, TweenFast, {BackgroundTransparency = 1}):Play()
                local tabImg = Tab.TabButton:FindFirstChildOfClass("ImageLabel")
                if tabImg then TweenService:Create(tabImg, TweenFast, {ImageColor3 = Theme.TextSecondary}):Play() end
                local tabTxt = Tab.TabButton:FindFirstChildOfClass("TextLabel")
                if tabTxt and not tabImg then TweenService:Create(tabTxt, TweenFast, {TextColor3 = Theme.TextSecondary}):Play() end
                local tbStroke2 = Tab.TabButton:FindFirstChildOfClass("UIStroke")
                if tbStroke2 then TweenService:Create(tbStroke2, TweenFast, {Transparency = 1}):Play() end
            end
            TabObj.Canvas.Visible = true
            TabObj.Canvas.GroupTransparency = WindowObj.CurrentTab and 1 or 0
            TweenService:Create(TabObj.Canvas, TweenSmooth, {GroupTransparency = 0}):Play()
            TweenService:Create(TabObj.TabButton, TweenFast, {BackgroundTransparency = 0}):Play()
            local activeImg = TabObj.TabButton:FindFirstChildOfClass("ImageLabel")
            if activeImg then TweenService:Create(activeImg, TweenFast, {ImageColor3 = Theme.Accent}):Play() end
            local activeTxt = TabObj.TabButton:FindFirstChildOfClass("TextLabel")
            if activeTxt and not activeImg then TweenService:Create(activeTxt, TweenFast, {TextColor3 = Theme.Accent}):Play() end
            local tbStroke = TabObj.TabButton:FindFirstChildOfClass("UIStroke")
            if tbStroke then TweenService:Create(tbStroke, TweenFast, {Transparency = 0}):Play() end
            WindowObj.CurrentTab = TabObj
        end

        function TabObj:Activate() ActivateTab() end
        if not IsConfig then
            TabBtn.MouseButton1Click:Connect(ActivateTab)
            local ActiveTabsCount = 0
            for _, t in WindowObj.Tabs do if not t.IsConfig then ActiveTabsCount += 1 end end
            if ActiveTabsCount == 1 then ActivateTab() end
        end

