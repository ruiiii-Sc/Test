local ConflictGroupManager = {}
ConflictGroupManager.__index = ConflictGroupManager
function ConflictGroupManager.new(options, groups)
    local self = setmetatable({}, ConflictGroupManager)
    self.state = {}
    for _, option in ipairs(options or {}) do self.state[option] = false end
    self.groups = groups or {}
    self.onChange = nil
    self.dependencies = {}
    return self
end
function ConflictGroupManager:toggle(optionName)
    if self.state[optionName] == nil then return nil end
    self.state[optionName] = not self.state[optionName]
    if self.state[optionName] then self:_applyConflicts(optionName) self:_applyDependencies(optionName) end
    self:_triggerCallback()
    return self.state
end
function ConflictGroupManager:set(optionName, value)
    if self.state[optionName] == nil then return nil end
    self.state[optionName] = value
    if value then self:_applyConflicts(optionName) self:_applyDependencies(optionName) end
    self:_triggerCallback()
    return self.state
end
function ConflictGroupManager:getState() return self.state end
function ConflictGroupManager:isActive(name) return self.state[name] or false end
function ConflictGroupManager:getActiveOptions()
    local active = {}
    for k, v in pairs(self.state) do if v then table.insert(active, k) end end
    return active
end
function ConflictGroupManager:reset()
    for k in pairs(self.state) do self.state[k] = false end
    self:_triggerCallback()
end
function ConflictGroupManager:_applyConflicts(changedName)
    for _, group in ipairs(self.groups) do
        local found = false
        for _, opt in ipairs(group) do if opt == changedName then found = true; break end end
        if found then
            for _, opt in ipairs(group) do if opt ~= changedName then self.state[opt] = false end end
            break
        end
    end
end
function ConflictGroupManager:_applyDependencies(changedName)
    for opt, req in pairs(self.dependencies) do
        if opt == changedName and self.state[opt] then
            if not self.state[req] then self.state[req] = true self:_applyConflicts(req) end
        elseif req == changedName and not self.state[req] then
            if self.state[opt] then self.state[opt] = false end
        end
    end
end
function ConflictGroupManager:_triggerCallback() if self.onChange then self.onChange(self.state) end end

Library.ConflictGroupManager = ConflictGroupManager

function Library:SetWindowKeybind(KeyEnum) self.ToggleKey = KeyEnum end
function Library:GetTheme() return Theme end
function Library:SetTheme(NewTheme)
    if not NewTheme then return end
    for Key, Value in pairs(NewTheme) do if Theme[Key] ~= nil then Theme[Key] = Value end end
    ApplyTheme()
end

