local enemyCache = {}
local lastEnemyScan = 0

local function getEnemies()
	local now = tick()
	if now - lastEnemyScan < 0.3 then return enemyCache end
	lastEnemyScan = now

	local current = {}
	local char = LP.Character
	if not char then return current end

	local ENEMY_COUNTER_BLACKLIST = {"Kraken Tentacle"}
	local function addEnemy(model)
		if not model or model == char then return end
		if Players:GetPlayerFromCharacter(model) then return end
		for _, bl in ipairs(ENEMY_COUNTER_BLACKLIST) do
			if model.Name == bl then return false end
		end
		local hum = model:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then
			table.insert(current, model)
			return true
		end
		return false
	end

	local dungeon = workspace:FindFirstChild("dungeon")
	if dungeon then
		for _, room in ipairs(dungeon:GetChildren()) do
			local enemyFolder = room:FindFirstChild("enemyFolder")
			if enemyFolder then
				for _, enemy in ipairs(enemyFolder:GetChildren()) do
					if enemy:IsA("Model") then addEnemy(enemy) end
				end
			end
			for _, child in ipairs(room:GetChildren()) do
				if child:IsA("Model") and child.Name ~= "enemyFolder" then addEnemy(child) end
			end
		end
	end

	for _, child in ipairs(workspace:GetChildren()) do
		if child:IsA("Model") and child ~= char and child.Name ~= "dungeon" then
			addEnemy(child)
		end
	end

	enemyCache = current
	return current
end

local function getNearestEnemy()
	local char = LP.Character
	if not char then return nil end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return nil end
	local origin = hrp.Position
	local best, bestDist = nil, math.huge
	local enemies = getEnemies()
	for _, enemy in ipairs(enemies) do
		local hum = enemy:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 then
			local root = enemy:FindFirstChild("HumanoidRootPart")
				or enemy:FindFirstChild("RootPart")
				or enemy:FindFirstChild("Root")
				or enemy:FindFirstChildOfClass("BasePart")
			if root then
				local dist = (root.Position - origin).Magnitude
				if dist < bestDist then
					bestDist = dist
					best = root
				end
			end
		end
	end
	return best
end

local function applyESP(enemy)
	if not enemy or not stateESP then return end
	if not enemy:FindFirstChild("__BeyonderESP") then
		local h = Instance.new("Highlight")
		h.Name = "__BeyonderESP"
		h.FillColor = Color3.fromRGB(180, 80, 255)
		h.OutlineColor = Color3.fromRGB(220, 180, 255)
		h.FillTransparency = 0.55
		h.OutlineTransparency = 0.1
		h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		h.Parent = enemy
	end
end

local function removeESP(enemy)
	local h = enemy and enemy:FindFirstChild("__BeyonderESP")
	if h then h:Destroy() end
end

local function updateESP()
	for _, e in ipairs(enemyCache) do
		if stateESP then applyESP(e) else removeESP(e) end
	end
end

