local function collectRemotes()
	local res = {}
	local added = {}
	local function add(child)
		if not child or not (child:IsA("RemoteEvent") or child:IsA("UnreliableRemoteEvent")) then return end
		if added[child] then return end
		local name = child.Name:lower()
		if name == "abilityevent" or name == "spellevent" or name == "abilitycast" or name == "abilityused" or name == "abilityCast" or name == "abilityUsed" then
			added[child] = true
			table.insert(res, {name = child.Name, remote = child})
		end
	end
	local function scan(src)
		if not src then return end
		for _, child in ipairs(src:GetChildren()) do add(child); scan(child) end
	end
	local bp = LP:FindFirstChild("Backpack")
	if bp then for _, t in ipairs(bp:GetChildren()) do if t:IsA("Tool") then scan(t) end end end
	if LP.Character then for _, t in ipairs(LP.Character:GetChildren()) do if t:IsA("Tool") then scan(t) end end end
	local rsRemotes = game:GetService("ReplicatedStorage"):FindFirstChild("remotes") or game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
	if rsRemotes then
		for _, r in ipairs(rsRemotes:GetChildren()) do add(r) end
		local abs = rsRemotes:FindFirstChild("abilities") or rsRemotes:FindFirstChild("Abilities")
		if abs then for _, r in ipairs(abs:GetChildren()) do add(r) end end
	end
	return res
end

