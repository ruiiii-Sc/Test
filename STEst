		if inputState == Enum.UserInputState.Begin then
			heightActiveKeys[key] = true
		elseif inputState == Enum.UserInputState.End then
			heightActiveKeys[key] = nil
		end
		local moveDir = 0
		if heightActiveKeys[upKey] then moveDir = 1 end
		if heightActiveKeys[downKey] then moveDir = -1 end
		vel.VectorVelocity = Vector3.new(0, moveDir * 35, 0)
		if airwalkPlat then airwalkPlat.CanCollide = (moveDir == 0) end
		return Enum.ContextActionResult.Sink
	end, false, 9e10, upKey, downKey)
