end)

startSpam = function()
	stopSpam()
	refreshRemotes()
	local thread = task.spawn(function()
		while _alive do
			if not stateSpam then task.wait(0.1); continue end
			local char = LP.Character
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			local target = getNearestEnemy()
			if target and hrp then
				local hum = char:FindFirstChildOfClass("Humanoid")
				if hum then
					hum.AutoRotate = false
					hrp.CFrame = CFrame.lookAt(hrp.Position, Vector3.new(target.Position.X, hrp.Position.Y, target.Position.Z))
				end
			end
			local pos = (target and target.Position) or (char and char:GetPivot().Position) or Vector3.zero
			local count = math.clamp(tonumber(spamCount) or 1, 1, 50)
			local bp = LP:FindFirstChild("Backpack")
			if bp then
				for _, tool in ipairs(bp:GetChildren()) do
					if not tool:IsA("Tool") then continue end
					local cdLen = tool:FindFirstChild("cooldownLength") or tool:FindFirstChild("cooldown")
					if cdLen then pcall(function() cdLen.Value = 0 end) end
					local slotVal = tool:FindFirstChild("abilitySlot")
					if slotVal then
						local k = slotVal.Value
						local n = (k == "q" or k == "ability_q") and 1 or 2
						pcall(function() LP:SetAttribute("AbilitySlot" .. n .. "Cooldown", 0) end)
					end
				end
			end
			if #remoteList > 0 then
				for _, data in ipairs(remoteList) do
					if data.remote and data.remote.Parent then
						for _ = 1, count do
							pcall(function() data.remote:FireServer(pos) end)
						end
					end
				end
			end
			task.wait(spamDelay)
		end
	end)
	table.insert(spamLoops, thread)
end

