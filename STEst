local function safeDestroy(inst)
	if inst and inst.Parent then
		pcall(IDestroy, inst)
	end
end

local function vfxCleanup(v)
	if not _alive then return end
	if not v or not v.Parent then return end
	local name = v.Name:lower()
	if name:find("cryonox") or name:find("ice elemental") or name:find("elemental") then return end
	if name:find("deatheffect") or name:find("npcdeath") or name:find("smite") or name:find("spirit") or name:find("phantom") then
		task.defer(safeDestroy, v)
		return
	end
	if stateAutoHideAbility or v:IsA("ParticleEmitter") then
		if v:IsA("ParticleEmitter") or v:IsA("Beam") or v:IsA("Trail") then
			task.defer(safeDestroy, v)
			return
		end
		if v:IsA("Model") or v:IsA("Folder") or v:IsA("BasePart") then
			for _, abName in ipairs(abilityNamesToHide) do
				if name:find(abName, 1, true) then
					task.defer(safeDestroy, v)
					return
				end
			end
		end
	end
end

local function applyInvisibleChar(char)
	if not char then return end
	local function hide(d)
		if d:IsA("BasePart") or d:IsA("Decal") then
			d.Transparency = stateInvisibleChar and 1 or 0
			if d.Name == "face" and stateInvisibleChar then d.Transparency = 1 end
		end
	end
	for _, d in ipairs(char:GetDescendants()) do hide(d) end
	local gear = workspace:FindFirstChild("asupotc") and workspace.asupotc:FindFirstChild("WeaponGear")
	if gear then
		for _, d in ipairs(gear:GetDescendants()) do
			if d:IsA("BasePart") or d:IsA("Decal") then d.Transparency = stateInvisibleChar and 1 or 0 end
		end
	end
	-- specific hides for WeaponGear, ChestGear, HelmetGear
	pcall(function()
		local gearFolder = workspace:FindFirstChild("asupotc")
		if gearFolder then
			local targets = {"WeaponGear", "ChestGear", "HelmetGear"}
			for _, t in ipairs(targets) do
				local g = gearFolder:FindFirstChild(t)
				if g then
					for _, d in ipairs(g:GetDescendants()) do
						if d:IsA("BasePart") or d:IsA("Decal") then d.Transparency = stateInvisibleChar and 1 or 0 end
					end
				end
			end
		end
	end)
end

