local function spendSkillPoint(statName, amount)
	local statMap = {
		["Stamina"] = "stamina", ["stamina"] = "stamina",
		["SpellPower"] = "spellPower", ["spell"] = "spellPower", ["spellPower"] = "spellPower",
		["PhysicalPower"] = "physicalPower", ["physical"] = "physicalPower", ["physicalPower"] = "physicalPower"
	}
	local actualStat = statMap[statName]
	if not actualStat then return end
	pcall(function()
		local Utility = game:GetService("ReplicatedStorage"):WaitForChild("Utility")
		local BridgeNet2 = require(Utility:WaitForChild("BridgeNet2"))
		local SkillpointBridge = BridgeNet2.ClientBridge("SkillpointBridge")
		local points = 0
		local valObj = LP:FindFirstChild("skillPoints") or (LP:FindFirstChild("leaderstats") and LP.leaderstats:FindFirstChild("Skill Points"))
		if valObj then
			points = valObj.Value
		else
			local PlayerValues = require(Utility:WaitForChild("PlayerValues"))
			local done = false
			PlayerValues.GetValueAsync(LP, "skillPoints"):andThen(function(v)
				points = v or 0
				done = true
			end)
			local start = tick()
			while not done and tick() - start < 1.5 do task.wait() end
		end
		local toSpend = math.min(points, amount or points)
		if toSpend > 0 then
			SkillpointBridge:InvokeServerAsync({stat = actualStat, amount = toSpend})
		end
	end)
end

