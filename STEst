local function getBestStatValue(item, stat)
	local d = item.data or item
	if stat == "Health" then
		return d.health or d.maxHealth or d.Health or 0
	elseif stat == "Physical" then
		return d.physicalPower or d.physPower or d.PhysicalPower or 0
	elseif stat == "Spell" then
		return d.spellPower or d.magicalPower or d.SpellPower or 0
	elseif stat == "Damage" or item.itemType == "ability" then
		return d.damage or d.Damage or 0
	end
	return 0
end

local lastEquipCheck = 0
local function doEquipBest()
	pcall(function()
		local Utility = game:GetService("ReplicatedStorage"):WaitForChild("Utility", 5)
		if not Utility then return end
		local BridgeNet2 = require(Utility:WaitForChild("BridgeNet2", 5))
		local GetInv = BridgeNet2.ClientBridge("GetInventoryBridge")
		local EquipBridge = BridgeNet2.ClientBridge("EquipItemBridge")
		local raw = GetInv:InvokeServerAsync()
		local str = typeof(raw) == "buffer" and buffer.tostring(raw) or raw
		local inv = HttpService:JSONDecode(str)
		local playerLevel = 0
		pcall(function() playerLevel = tonumber(LP.leaderstats.Level.Value) or 0 end)
		local allowedTypes = {weapon = true, helmet = true, chest = true}
		local bestItems, maxValues, bestIds = {}, {}, {}
		for id, item in pairs(inv) do
			if type(item) ~= "table" then continue end
			local iType = item.itemType
			if not iType or not allowedTypes[iType] then continue end
			if iType == "weapon" and valPriorityStat == "Health" then continue end
			local d = item.data or item
			local itemLevel = tonumber(d.levelReq) or 0
			if itemLevel > playerLevel then continue end
			local val = getBestStatValue(item, valPriorityStat)
			if not bestItems[iType] or val > (maxValues[iType] or 0) then
				maxValues[iType] = val; bestItems[iType] = item; bestIds[iType] = tostring(id)
			elseif val == maxValues[iType] then
				local lv = (item.data and item.data.levelReq) or 0
				local blv = (bestItems[iType].data and bestItems[iType].data.levelReq) or 0
				if lv > blv then bestItems[iType] = item; bestIds[iType] = tostring(id) end
			end
		end
		for iType, item in pairs(bestItems) do
			if item and not item.equipped then
				EquipBridge:InvokeServerAsync({id = bestIds[iType], itemType = item.itemType, data = item.data})
				task.wait(0.15)
			end
		end
	end)
end
local function triggerAutoEquip()
	if not stateAutoEquipBest then return end
	doEquipBest()
end

local rarityLevels = { ["Common"] = 1, ["Uncommon"] = 2, ["Rare"] = 3, ["Epic"] = 4, ["Legendary"] = 5, ["Ultimate"] = 6, ["All"] = 99 }
local function shouldSell(item)
	if not item then return false end
	local iType = item.itemType
	if iType == "ring" then
		local eq = item.equipped
		if type(eq) == "table" then
			for _, v in pairs(eq) do if v == true then return false end end
		elseif eq == true then
			return false
		end
	else
		if item.equipped then return false end
	end
	local mapped = (iType == "helmet" or iType == "chest") and "Armors" or (iType == "weapon" and "Weapons") or (iType == "ring" and "Rings")
	if not mapped or not sellTypes[mapped] then return false end
	local d = item.data or item
	local r = d.rarity or "Common"
	local lv = tonumber(d.levelReq) or 0
	if sellRarity ~= "All" and sellRarity:sub(1,1) == "<" then
		if (rarityLevels[r] or 1) >= (rarityLevels[sellRarity:sub(2)] or 2) then return false end
	end
	if sellLevel ~= "All" and sellLevel:sub(1,1) == "<" then
		if lv >= (tonumber(sellLevel:sub(2)) or 11) then return false end
	end
	return true
end

local isSelling = false
local function doSellNow()
	pcall(function()
		local RS = game:GetService("ReplicatedStorage")
		local sellEvent = RS.remotes and RS.remotes:FindFirstChild("sellItemEvent")
		if not sellEvent then return end
		local inv = RS.remotes.reloadInvy:InvokeServer()
		if not inv then return end
		local grouped = {ability={}, chest={}, helmet={}, ring={}, weapon={}}
		local prefixMap = {weapon=7, ability=8, chest=6, helmet=7, ring=5}
		local function processType(tbl, typeName)
			if not tbl then return end
			for key, item in pairs(tbl) do
				if type(item) ~= "table" then continue end
				item.itemType = typeName
				if not shouldSell(item) then continue end
				local num = tonumber(string.sub(key, prefixMap[typeName] + 1))
				if num then table.insert(grouped[typeName], num) end
			end
		end
		processType(inv.weapons, "weapon")
		processType(inv.abilities, "ability")
		processType(inv.chests, "chest")
		processType(inv.helmets, "helmet")
		processType(inv.rings, "ring")
		local hasAny = false
		for _, t in pairs(grouped) do if #t > 0 then hasAny = true; break end end
		if hasAny then sellEvent:FireServer(grouped) end
	end)
end
local function triggerAutoSell()
