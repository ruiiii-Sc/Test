local cameraShakeConn = nil
local function applyCameraShakeFix()
	if cameraShakeConn then cameraShakeConn:Disconnect(); cameraShakeConn = nil end
	if not stateNoCameraShake then return end
	local lastCF = workspace.CurrentCamera and workspace.CurrentCamera.CFrame
	cameraShakeConn = connect(RunService.RenderStepped, function()
		if not stateNoCameraShake then
			if cameraShakeConn then cameraShakeConn:Disconnect(); cameraShakeConn = nil end
			return
		end
		local cam = workspace.CurrentCamera
		if not cam then return end
		if lastCF then
			local cur = cam.CFrame
			local diff = (cur.Position - lastCF.Position).Magnitude
			if diff < 0.5 then
				cam.CFrame = lastCF
			else
				lastCF = cur
			end
		else
			lastCF = cam.CFrame
		end
	end)
end
task.spawn(applyCameraShakeFix)

