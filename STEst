	local downKey = getHeightKeyEnum(heightKeyDown)
	ContextActionService:BindActionAtPriority(stateAdjustHeightActionName, function(_, inputState, inputObject)
		if not stateAdjustHeight then return Enum.ContextActionResult.Pass end
		local key = inputObject.KeyCode
		if key ~= upKey and key ~= downKey then
			return Enum.ContextActionResult.Pass
		end
		local char = LP.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if not hrp then return Enum.ContextActionResult.Sink end
		local vel = hrp:FindFirstChild("__AirwalkVel")
