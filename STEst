SpeedRow:SubTextbox({Title = "WalkSpeed", Placeholder = "16", Default = tostring(valWalkSpeed), Callback = function(val)
	valWalkSpeed = tonumber(val) or 16; cfg.valWalkSpeed = valWalkSpeed; saveCfg()
end})
SpeedRow:SubTextbox({Title = "JumpPower", Placeholder = "10", Default = tostring(valJumpPower), Callback = function(val)
	valJumpPower = tonumber(val) or 10; cfg.valJumpPower = valJumpPower; saveCfg()
end})

MiscTab:Toggle({Title = "Airwalk", Default = stateAirwalk, Callback = function(val)
	stateAirwalk = val; cfg.airwalk = val; saveCfg()
	if val then task.spawn(startAirwalk) else stopAirwalk() end
end})

local HeightRow = MiscTab:Row({Title = "Height Control"})
HeightRow:SubTextbox({Title = "Step (studs)", Placeholder = "3", Default = tostring(heightStep), Callback = function(val)
	heightStep = tonumber(val) or 3; cfg.heightStep = heightStep; saveCfg()
end})
HeightRow:SubKeybind({Title = "Up Key", Default = Enum.KeyCode[heightKeyUp], Callback = function(key)
	heightKeyUp = key.Name; cfg.heightKeyUp = heightKeyUp; saveCfg()
	if stateAdjustHeight then stopAdjustHeight(); startAdjustHeight() end
end})
HeightRow:SubKeybind({Title = "Down Key", Default = Enum.KeyCode[heightKeyDown], Callback = function(key)
	heightKeyDown = key.Name; cfg.heightKeyDown = heightKeyDown; saveCfg()
	if stateAdjustHeight then stopAdjustHeight(); startAdjustHeight() end
end})
HeightRow:SubToggle({Title = "Height Control", Default = stateAdjustHeight, Callback = function(val)
	stateAdjustHeight = val; cfg.adjustHeight = val; saveCfg()
	if val then task.spawn(startAdjustHeight) else stopAdjustHeight(); stateAirwalk = false; cfg.airwalk = false; saveCfg(); stopAirwalk() end
end})

MiscTab:Toggle({Title = "Noclip", Default = stateNoclip, Callback = function(val)
	stateNoclip = val; cfg.noclip = val; saveCfg()
	if val then task.spawn(startNoclip) else stopNoclip() end
end})

MiscTab:Toggle({Title = "Infinite Jump", Default = stateInfJump, Callback = function(val)
	stateInfJump = val; cfg.stateInfJump = val; saveCfg()
end})

MiscTab:Line()

MiscTab:Toggle({Title = "Invisicam", Default = stateInviscam, Callback = function(val)
	stateInviscam = val; cfg.inviscam = val; saveCfg(); applyInvisicam()
end})
MiscTab:Toggle({Title = "Infinite Zoom", Default = stateZoom, Callback = function(val)
	stateZoom = val; cfg.zoom = val; saveCfg(); applyZoom()
end})
MiscTab:Toggle({Title = "Disable Camera Shake", Default = stateNoCameraShake, Callback = function(val)
	stateNoCameraShake = val; cfg.noCameraShake = val; saveCfg()
	applyCameraShakeFix()
end})

MiscTab:Line()

local AutoStatRow = MiscTab:Row({Title = "Auto Stats"})
AutoStatRow:SubDropdown({Title = "Target", Options = {"physical", "spell", "stamina"}, Default = autoStatTarget, Callback = function(val)
	autoStatTarget = val; cfg.autoStatTarget = val; saveCfg()
end})
AutoStatRow:SubToggle({Title = "Enable", Default = stateAutoStats, Callback = function(val)
	stateAutoStats = val; cfg.autoStats = val; saveCfg()
end})

MiscTab:Button({Title = "Reset Skill Points", Action = "Reset", Callback = function()
	pcall(function()
		local remotes = game:GetService("ReplicatedStorage"):WaitForChild("remotes", 1)
		if not remotes then return end
		local r1 = remotes:FindFirstChild("resetSkillPoints")
		if r1 then r1:FireServer() end
	end)
end})

MiscTab:Button({Title = "Force Close", Action = "ForceClose", Callback = function()
	pcall(function()
		local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("remotes")
		local leaveRemote = remotes and remotes:FindFirstChild("leaveGame")
		if leaveRemote then leaveRemote:FireServer() end
	end)
	pcall(function() game:GetService("TeleportService"):Teleport(game.PlaceId) end)
	pcall(function() game:Shutdown() end)
end})

MiscTab:Line()

local CBRow = MiscTab:Row({Title = "Counter Bar"})
CBRow:SubButton({Title = "Reset Position", Action = "Reset", Callback = function()
	counterFrame.Position = UDim2.new(1, -122, 0, 12)
	cfg.counterBarX = -122; cfg.counterBarY = 2; saveCfg()
end})
CBRow:SubToggle({Title = "Show", Default = not barHidden, Callback = function(val)
	barHidden = not val; counterFrame.Visible = val; cfg.counterBarHidden = barHidden; saveCfg()
end})

local lastAutoEquip = 0
local lastAutoSellTime = 0
local lastAutoStatTime = 0
local lastAutoClaimTime = 0

connect(RunService.Heartbeat, function()
	if not _alive then return end
	local now = tick()
	if stateAutoStats and now - lastAutoStatTime >= 1 then
		lastAutoStatTime = now
		task.spawn(function() spendSkillPoint(autoStatTarget, 1000) end)
	end
	if stateAutoEquipBest and now - lastAutoEquip > 1 then
		lastAutoEquip = now
		task.spawn(triggerAutoEquip)
	end
	if stateAutoSell and now - lastAutoSellTime > 1 then
		lastAutoSellTime = now
		task.spawn(triggerAutoSell)
	end
	if stateAutoClaimQuest and now - lastAutoClaimTime > 1 then
		lastAutoClaimTime = now
		task.spawn(doAutoClaimQuest)
	end
	if stateAutoStartDungeon then task.spawn(triggerAutoStart) end
	if stateAutoRetry then task.spawn(triggerAutoRetry) end
end)

if stateSpam then task.spawn(startSpam) end
if stateAimbot then task.spawn(startAimbot) end
if stateAirwalk then task.spawn(startAirwalk) end
if stateNoclip then task.spawn(startNoclip) end
if stateAdjustHeight then task.spawn(startAdjustHeight) end

task.delay(1, function()
	if stateAutoEquipBest then task.spawn(triggerAutoEquip) end
end)
